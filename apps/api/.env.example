# Finance Superbrain API — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic Claude API key (required)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Supabase Postgres connection (transaction pooler port 6543)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# Repository backend: postgres (production) or pglite (local dev only)
REPOSITORY_BACKEND=postgres
PGLITE_DATA_DIR=

# Market data backend: mock (no real data) or live
MARKET_DATA_BACKEND=mock

# Chat model backend: mock for deterministic demo mode, live for model-backed answers
CHAT_MODEL_BACKEND=mock

# Voyage AI embedding key (optional but strongly recommended)
# Sign up free at https://www.voyageai.com — 200M tokens free tier
# When set, enables voyage-finance-2 (finance-tuned neural embeddings)
# When absent, falls back to hash-vector similarity (weaker retrieval)
VOYAGE_API_KEY=

# Embedding backend (set to "voyage" when VOYAGE_API_KEY is present)
EMBEDDING_BACKEND=local

# Server
PORT=3099
HOST=0.0.0.0

# Internal workspace auth
AUTH_SESSION_TTL_HOURS=168
AUTH_COOKIE_SECURE=false
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_LOGIN_BLOCK_MINUTES=15

# Obsidian local memory bridge
OBSIDIAN_VAULT_PATH=
OBSIDIAN_EXPORT_ROOT=Finance Superbrain
FINANCE_SUPERBRAIN_APP_URL=http://localhost:3000
OBSIDIAN_IMPORT_INBOX=Finance Superbrain/Human Inbox
OBSIDIAN_IMPORT_MAX_NOTES=50
